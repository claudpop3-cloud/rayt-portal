# ─────────────────────────────────────────────────────────────────────────────
# Шаблон переменных окружения. Скопируйте в .env.local (локально) и/или задайте
# те же ключи в Vercel → Settings → Environment Variables (прод).
# .env.local в git НЕ попадает (см. .gitignore). Секреты в чат не вставлять.
# ─────────────────────────────────────────────────────────────────────────────

# ИИ-разбор ответов квиза (обязательно для работы анализа).
OPENAI_API_KEY=

# Админка (Basic-Auth на /admin/*). В проде задайте свой логин/пароль!
ADMIN_USER=admin
ADMIN_PASSWORD=смените-меня

# ─── Хранилище на проде: Upstash Redis (Vercel-ФС read-only) ───
# Если НЕ заданы — приложение работает на локальных файлах data/*.json (dev).
# Если заданы — заявки и правки контента из админки пишутся в Redis и переживают
# перезапуски/деплои. При подключении Upstash через Vercel Marketplace эти две
# переменные добавляются в проект автоматически — вручную вписывать не нужно.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Заявки: дубль-каналы (опционально, но желательно) ───
# Telegram: заявки приходят владельцу в чат. Бот у @BotFather → токен;
# chat_id — напр. через @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Вебхук (Google Sheets/CRM/бот): если задан, заявка POST-ится сюда JSON-ом.
LEADS_WEBHOOK_URL=
